{
  "name": "mirabit-backend",
  "version": "1.0.0",
  "description": "MiraBit Bitcoin Wallet Backend – Nostr-authenticated Lightning Network payments for students",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand --forceExit",
    "test:coverage": "jest --runInBand --coverage --forceExit",
    "test:watch": "jest --runInBand --watch",
    "lint": "eslint src/**/*.js"
  },
  "dependencies": {
    "@breeztech/breez-sdk-liquid": "^0.11.13",
    "bip39": "^3.1.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "joi": "^17.13.1",
    "mongoose": "^9.6.2",
    "morgan": "^1.10.0",
    "nostr-tools": "^2.23.5",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^10.0.0",
    "winston": "^3.13.0",
    "ws": "^8.17.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "babel-jest": "^30.4.1",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^11.1.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "testTimeout": 30000,
    "testMatch": [
      "<rootDir>/tests/**/*.test.js"
    ],
    "globalSetup": "<rootDir>/tests/globalSetup.js",
    "globalTeardown": "<rootDir>/tests/globalTeardown.js",
    "transformIgnorePatterns": [
      "/node_modules/(?!(nostr-tools|@noble|@scure)/)"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/docs/**",
      "!src/data/**"
    ],
    "verbose": true
  }
}
