# ─────────────────────────────────────────────
#   MiraBit Backend – Environment Variables
# ─────────────────────────────────────────────

# Application
NODE_ENV=development
PORT=5000
API_VERSION=v1

# CORS – comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─────────────────────────────────────────────
# Database (MongoDB Atlas)
# ─────────────────────────────────────────────
# Get your connection string from: https://cloud.mongodb.com → Database → Connect → Drivers
# Format: mongodb+srv://<user>:<password>@<cluster>.<id>.mongodb.net/?retryWrites=true&w=majority&appName=<AppName>
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority&appName=MiraBit

# Logical database name within the Atlas cluster
MONGODB_DB_NAME=mirabit

# Connection pool tuning (defaults are sensible for small/medium load)
MONGODB_MAX_POOL_SIZE=10
MONGODB_MIN_POOL_SIZE=2

# ─────────────────────────────────────────────
# Breez SDK (Lightning Network via Liquid)
# ─────────────────────────────────────────────
# API key from https://breez.technology
BREEZ_API_KEY=your_breez_api_key_here

# BIP-39 mnemonic for the Lightning wallet (NEVER commit the real value)
BREEZ_MNEMONIC=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12

# Working directory for Breez SDK data
BREEZ_WORKING_DIR=./breez_data

# ─────────────────────────────────────────────
# Nostr
# ─────────────────────────────────────────────
# Hex-encoded 32-byte private key for the backend Nostr identity
NOSTR_PRIVATE_KEY=your_nostr_hex_privkey_here

# Comma-separated list of relay WebSocket URLs
NOSTR_RELAYS=wss://relay.damus.io,wss://relay.nostr.band,wss://nos.lol,wss://relay.snort.social

# ─────────────────────────────────────────────
# Currency Conversion
# ─────────────────────────────────────────────
# CoinGecko API (free tier works; get key at https://coingecko.com)
COINGECKO_API_URL=https://api.coingecko.com/api/v3
COINGECKO_API_KEY=

# Exchange rate cache TTL in seconds
RATE_CACHE_TTL_SECONDS=60

# ─────────────────────────────────────────────
# Rate Limiting
# ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────
LOG_LEVEL=debug
LOG_DIR=./logs
