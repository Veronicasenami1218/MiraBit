# ─────────────────────────────────────────────
#   MiraBit Frontend – Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env (which is git-ignored) and fill in real values.

# Base URL of the MiraBit backend API (must include /api/v1).
# Leave blank to run the frontend in localStorage-only demo mode.
VITE_API_BASE_URL=http://localhost:5000/api/v1
